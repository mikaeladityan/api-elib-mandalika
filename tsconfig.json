{
    "compilerOptions": {
        /* Runtime & Language */
        "target": "ES2022",
        "lib": ["ES2022", "DOM"],
        "module": "nodenext",
        "moduleResolution": "NodeNext",

        /* Strictness */
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "useUnknownInCatchVariables": true,

        /* Interop */
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,

        /* Emit */
        "rootDir": "./src",
        "outDir": "dist",
        "sourceMap": true,

        /* Safety */
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": ["src", "prisma", "pkg/generate.hex.js"],

    "exclude": ["node_modules", "dist"]
}
